# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lockfiles
# 建议保留锁文件用于复现依赖版本，因此这里不忽略 package-lock.json / pnpm-lock.yaml

# Production builds
frontend/dist/
dist/
build/
*.tsbuildinfo

# Runtime data
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
.dev-processes.json
pids/
*.pid
*.pid.lock
*.seed
logs/
*.log

# Environment variables
.env
.env.*
!.env.example

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Cache / temp
.cache/
tmp/
temp/
.npm/

# Coverage
coverage/
.nyc_output/

# Optional package outputs
*.tgz
jspm_packages/
.node_repl_history
.yarn-integrity

# Local/private files
server/config.json

docker/**/*.docker
docker/**/*.zip
docker/**/*.tar
docker/**/*.tar.gz
docker/**/*.tgz

