# Example environment variables for production deployment.
# This project does not automatically load .env by itself.
# You can:
# 1) export these variables in the shell before starting the app, or
# 2) copy the values into ecosystem.config.cjs for PM2 deployment.

NODE_ENV=production
HOST=0.0.0.0
PORT=3001
DB_PATH=./data/xyzw.db

# Replace with your own secure values before production use.
JWT_SECRET=replace_with_a_strong_jwt_secret
ENCRYPTION_KEY=replace_with_a_strong_32_byte_key

# Optional overrides
GAME_CLIENT_VERSION=2.3.9-wx
GAME_BATTLE_VERSION=241201
MAX_CONCURRENT_ACCOUNTS=5
